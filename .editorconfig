root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.{json,yml,yaml,xml,csproj,props,targets,sln}]
indent_size = 2

[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{cs,vb}]
indent_size = 4
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# Code style — namespaces and usings
csharp_using_directive_placement = outside_namespace:warning
csharp_style_namespace_declarations = file_scoped:warning

# var preferences
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion

# Expression-bodied
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_constructors = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = when_on_single_line:suggestion

# Modifier order
csharp_preferred_modifier_order = public,private,protected,internal,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,volatile,async:warning

# Nullable
dotnet_diagnostic.CS8600.severity = warning
dotnet_diagnostic.CS8602.severity = warning
dotnet_diagnostic.CS8603.severity = warning
dotnet_diagnostic.CS8625.severity = warning

# IDE diagnostics commonly noisy in templates
dotnet_diagnostic.IDE0058.severity = none
dotnet_diagnostic.IDE0008.severity = none

# F7.1: regras de analyzer silenciadas no escopo inteiro com justificativa.
#
# CA1848 (Use LoggerMessage delegates for performance): micro-otimização recomendada
#   apenas em hot paths comprovados. Os logs do projeto são por requisição e não
#   estão num hot path mensurável; o ganho de LoggerMessage delegates não compensa
#   o ruído de boilerplate em ~50 call-sites. Avaliar caso a caso se aparecer
#   no perf profile.
dotnet_diagnostic.CA1848.severity = none

# MA0004 (Use ConfigureAwait): em ASP.NET Core 6+ não há SynchronizationContext,
#   portanto ConfigureAwait(false) é no-op funcional. Mantemos sintaxe limpa.
#   Em libs reutilizáveis (SharedKernel) mantemos ConfigureAwait(false) por
#   higiene (já aplicado pelo dotnet format no Passo 2).
dotnet_diagnostic.MA0004.severity = none

# CA1716 (Identifiers conflicting with VB keywords): projeto é C#-only.
#   Nomes naturais do domínio (Error, To, Date) seguem.
dotnet_diagnostic.CA1716.severity = none

# CA1000 (Don't declare static members on generic types): conflita com o padrão
#   Railway-oriented (Result<T>.Success/Failure) usado pelo SharedKernel.
#   A inconveniência de não ter sintaxe de fábrica genérica supera o ganho.
dotnet_diagnostic.CA1000.severity = none

# MA0048 (File name must match type name): C# permite múltiplos tipos por arquivo
#   por design. Em DTOs/Requests/responses fortemente coesos (ex.: RegisterEntryRequest
#   + AmountRequest + ReverseEntryRequest no mesmo arquivo de feature) a coesão
#   visual supera o purismo do "one type per file". Tipos grandes são separados
#   por padrão de design (ver §F8 / blueprint).
dotnet_diagnostic.MA0048.severity = none

[tests/**/*.cs]
# CA1707 (Identifiers should not contain underscores): conflita com o naming
#   pattern Method_Scenario_ExpectedResult que é o padrão do projeto para testes
#   (blueprint §08-TESTES.md §1.3). Silenciado apenas em tests/.
dotnet_diagnostic.CA1707.severity = none

# F7.1: CA1861 (Prefer 'static readonly' arrays) — silenciado em Program.cs
#   (boot one-shot, sem hot path) e em test infra (TestTokens carrega 1x por
#   suite). Endereçado caso a caso em endpoint filters / handlers onde realmente
#   reside hot path.
[**/Program.cs]
dotnet_diagnostic.CA1861.severity = none

[**/TestTokens.cs]
dotnet_diagnostic.CA1861.severity = none

[*.{razor,cshtml}]
indent_size = 4
