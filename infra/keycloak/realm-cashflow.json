{
  "realm": "cashflow",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,

  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,

  "roles": {
    "realm": [
      { "name": "merchant", "description": "Merchant role — write/read próprios lançamentos." },
      { "name": "admin",    "description": "Admin role  — endpoints administrativos." }
    ]
  },

  "clientScopes": [
    {
      "name": "merchantId-scope",
      "description": "Inclui o claim merchantId no token (User Attribute mapper).",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "merchantId",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "merchantId",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "merchantId",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],

  "defaultDefaultClientScopes": [
    "merchantId-scope"
  ],

  "clients": [
    {
      "clientId": "cashflow-api",
      "name": "Cashflow API (confidential)",
      "description": "Client confidential para back-end e scripts (CI/k6/chaos). Suporta `password` grant (uso primário em scripts e README) e `client_credentials` via service account.",
      "enabled": true,
      "publicClient": false,
      "secret": "cashflow-api-secret",
      "protocol": "openid-connect",
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "fullScopeAllowed": true,
      "attributes": {
        "access.token.lifespan": "300"
      },
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email",
        "merchantId-scope"
      ],
      "protocolMappers": [
        {
          "name": "merchantId",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "merchantId",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "merchantId",
            "jsonType.label": "String"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "role",
            "jsonType.label": "String"
          }
        },
        {
          "name": "preferred_username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "preferred_username",
            "jsonType.label": "String"
          }
        },
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "email",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "email",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "cashflow-web",
      "name": "Cashflow Web (public, PKCE)",
      "description": "Client público usado pelo frontend Next.js (Authorization Code + PKCE).",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "http://localhost:3001/*"
      ],
      "webOrigins": [
        "http://localhost:3001"
      ],
      "attributes": {
        "access.token.lifespan": "300",
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3001/*"
      },
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email",
        "merchantId-scope"
      ],
      "protocolMappers": [
        {
          "name": "merchantId",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "merchantId",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "merchantId",
            "jsonType.label": "String"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "role",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],

  "users": [
    {
      "username": "merchant1@cashflow.local",
      "email": "merchant1@cashflow.local",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Merchant",
      "lastName": "One",
      "attributes": {
        "merchantId": ["0193e7a8-d8f0-7c5e-9b21-3f9f8a4d1c00"]
      },
      "credentials": [
        { "type": "password", "value": "merchant123", "temporary": false }
      ],
      "realmRoles": ["merchant"]
    },
    {
      "username": "admin@cashflow.local",
      "email": "admin@cashflow.local",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "User",
      "attributes": {
        "merchantId": ["0193e7a8-d8f0-7c5e-9b21-3f9f8a4d1c00"]
      },
      "credentials": [
        { "type": "password", "value": "admin123", "temporary": false }
      ],
      "realmRoles": ["admin", "merchant"]
    }
  ]
}
