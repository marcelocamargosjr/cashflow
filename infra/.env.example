# ============================================================================
#  Cashflow — Variáveis de ambiente (template).
#
#  IMPORTANTE: este arquivo é versionado em Git (placeholder values only).
#  Copie para `infra/.env` e substitua os `CHANGE_ME_IN_PROD` antes de subir.
#  O `.env` real está no `.gitignore`.
#
#  Convenção: `<COMPONENT>__<KEY>` (duplo underline) mapeia em IOptions<T> .NET.
# ============================================================================

# ===== POSTGRES =====
POSTGRES_USER=cashflow
POSTGRES_PASSWORD=CHANGE_ME_IN_PROD
POSTGRES_DB=cashflow_ledger

# ===== MONGO =====
MONGO_INITDB_ROOT_USERNAME=cashflow
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_IN_PROD

# ===== RABBITMQ =====
RABBITMQ_DEFAULT_USER=cashflow
RABBITMQ_DEFAULT_PASS=CHANGE_ME_IN_PROD

# ===== KEYCLOAK =====
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_IN_PROD

# ===== APP (compartilhado pelas APIs/Worker/Gateway) =====
ASPNETCORE_ENVIRONMENT=Development

# Connection strings — host `postgres`/`mongo`/`rabbitmq`/`redis` resolvem
# dentro da network `cashflow-net` (DNS interno do Docker Compose).
ConnectionStrings__Postgres=Host=postgres;Port=5432;Database=cashflow_ledger;Username=cashflow;Password=CHANGE_ME_IN_PROD;Include Error Detail=true
Mongo__ConnectionString=mongodb://cashflow:CHANGE_ME_IN_PROD@mongo:27017/cashflow_consolidation?authSource=admin
Redis__ConnectionString=redis:6379

RabbitMq__Host=rabbitmq
RabbitMq__Port=5672
RabbitMq__VirtualHost=/
RabbitMq__Username=cashflow
RabbitMq__Password=CHANGE_ME_IN_PROD

# Keycloak — Authority deve usar o mesmo host que o navegador usa (`localhost`)
# para o `iss` do JWT bater com o validador. Containers resolvem `localhost`
# via `extra_hosts: ["localhost:host-gateway"]` em cada serviço .NET (§07 §3.1.1).
Keycloak__Authority=http://localhost:8080/realms/cashflow
Keycloak__Audience=cashflow-api
Keycloak__RequireHttpsMetadata=false
# MetadataAddress aponta para a DNS interna do compose para que o JwtBearer fetche
# JWKS sem cair em loopback no container. Authority/iss continuam como `localhost`.
Keycloak__MetadataAddress=http://keycloak:8080/realms/cashflow/.well-known/openid-configuration

OTel__Endpoint=http://otel-collector:4317
