      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_request_duration_seconds_count{service_name=\"cashflow.consolidation.api\"}[1m]))",
          "refId": "A"
