      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_request_duration_seconds_count{service_name=\"cashflow.consolidation.api\",http_response_status_code=~\"5..|429\"}[30s])) / clamp_min(sum(rate(http_server_request_duration_seconds_count{service_name=\"cashflow.consolidation.api\"}[30s])), 1e-9)",
          "legendFormat": "consolidation error rate",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "0.05",
          "legendFormat": "5% NFR threshold",
          "refId": "B"
        }
