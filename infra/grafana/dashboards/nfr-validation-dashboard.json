    {
      "type": "stat",
      "title": "Success rate (now)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "1 - (sum(rate(http_server_request_duration_seconds_count{service_name=\"cashflow.consolidation.api\",http_response_status_code=~\"5..|429\"}[1m])) / clamp_min(sum(rate(http_server_request_duration_seconds_count{service_name=\"cashflow.consolidation.api\"}[1m])), 1e-9))",
          "refId": "A"
        }
      ]
    },
