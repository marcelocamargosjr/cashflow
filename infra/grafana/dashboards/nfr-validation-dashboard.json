      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 11, "w": 24, "x": 0, "y": 7 },
      "id": 5,
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 0.2,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 3,
            "fillOpacity": 20,
            "spanNulls": true,
            "thresholdsStyle": { "mode": "line+area" }
